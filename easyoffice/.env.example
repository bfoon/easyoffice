# =============================================================
# EasyOffice Environment Configuration
# Copy this to .env and update values before running
# =============================================================

# Django
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Office Branding
OFFICE_NAME=EasyOffice
OFFICE_TAGLINE=Your Virtual Office Management Platform
OFFICE_LOGO_URL=
OFFICE_PRIMARY_COLOR=#1e3a5f
OFFICE_ACCENT_COLOR=#2196f3

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=easyoffice
DB_USER=easyoffice
DB_PASSWORD=easyoffice_secret
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EasyOffice <noreply@easyoffice.com>

# Storage (set to 'local' or 's3')
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Media
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Security (set to True in production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Timezone
TIME_ZONE=UTC
LANGUAGE_CODE=en-us

# Pagination
DEFAULT_PAGE_SIZE=25

# File Upload Limits (in MB)
MAX_UPLOAD_SIZE=50
